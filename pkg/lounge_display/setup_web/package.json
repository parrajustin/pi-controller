{
  "name": "setup_web",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "esbuild src/app.ts src/upload.ts --bundle --outdir=dist --loader:.png=file --public-path=dist",
    "watch": "esbuild src/app.ts src/upload.ts --bundle --outdir=dist --watch --loader:.png=file --public-path=dist",
    "dev": "concurrently \"npm run watch\" \"live-server\"",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@material/web": "2.4.1",
    "lit": "3.3.3",
    "qrcode": "^1.5.4",
    "standard-ts-lib": "git+https://github.com/parrajustin/standard-ts-lib.git"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "concurrently": "10.0.3",
    "esbuild": "0.28.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "gts": "7.0.0",
    "live-server": "1.2.2",
    "prettier": "3.9.4",
    "typescript": "6.0.3"
  }
}
